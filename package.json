{
  "name": "agentconnect",
  "version": "0.5.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "dev:webhooks": "tsx scripts/dev-webhooks.ts",
    "mcp:stdio": "tsx src/mcp-stdio.ts",
    "worker:webhooks": "tsx src/worker/outbound-webhooks.ts",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "test:integration": "drizzle-kit migrate && tsx --test tests/*.integration.ts",
    "test:stripe-live": "drizzle-kit migrate && tsx --test tests/stripe-live.integration.ts",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:integration",
    "fix": "pnpm run lint:fix && pnpm run format",
    "prepare": "node scripts/setup-git-hooks.cjs",
    "db:push": "drizzle-kit push --force",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "agentmail": "^0.4.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "stripe": "^20.4.1",
    "svix": "^1.86.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "neostandard": "^0.13.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
